COPY --from=ref_p8 /work/marker /work/marker_p8
COPY --from=ref_p9 /work/marker /work/marker_p9
COPY --from=ref_p10 /work/marker /work/marker_p10
COPY --from=ref_p11 /work/marker /work/marker_p11
COPY --from=ref_p12 /work/marker /work/marker_p12
COPY --from=ref_p13 /work/marker /work/marker_p13
COPY --from=ref_p14 /work/marker /work/marker_p14
COPY --from=ref_p15 /work/marker /work/marker_p15
COPY --from=ref_p16 /work/marker /work/marker_p16
